			"group": "build"
		},
		{
			"label": "Run static site (npx cmd)",
			"type": "shell",
			"command": "npx.cmd",
			"args": [
				"--yes",
				"http-server",
				".",
				"-p",
				"5500"
			],
			"isBackground": true,
			"group": "build"
		}
